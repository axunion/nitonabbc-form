---
import ExpiredMessage from "@/components/forms/ExpiredMessage.tsx";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import Main from "@/components/layout/Main.astro";
import FormLayout from "@/layouts/FormLayout.astro";
---

<FormLayout title="京葉地区一泊お泊まり会アンケート">
	<Header>
		<h1 slot="title" class="title">
			京葉地区一泊お泊まり会アンケート<br />
			Keiyo Area Retreat Survey
		</h1>
		<p slot="description" class="description">
			開催日：2024年9月22日〜23日<br />
			Event Dates: September 22-23, 2024
		</p>
	</Header>

	<Main>
		<ExpiredMessage>
			<p>
				このアンケートは終了しています。
				<br />
				This survey is closed.
			</p>
		</ExpiredMessage>
	</Main>

	<Footer>
		<p class="footer-note">
			<small>© 2024 Keiyo Area United Youth Association.</small>
		</p>
	</Footer>
</FormLayout>

<style>
	.title {
		font-size: var(--text-xl);
		font-weight: bold;
		letter-spacing: -0.025em;

		@media (min-width: 768px) {
			font-size: var(--text-2xl);
		}
	}

	.description {
		font-size: var(--text-sm);
		color: var(--color-blue-100);

		@media (min-width: 768px) {
			font-size: var(--text-base);
		}
	}

	.footer-note {
		padding-top: var(--space-12);
	}
</style>
