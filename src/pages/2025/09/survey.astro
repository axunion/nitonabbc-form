---
import ExpiredMessage from "@/components/forms/ExpiredMessage.tsx";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import Main from "@/components/layout/Main.astro";
import FormLayout from "@/layouts/FormLayout.astro";
// import SurveyForm from "./_survey-form.tsx";
---

<FormLayout title="京葉地区青年キャンプ アンケート">
	<Header>
		<h1 slot="title" class="title">
			京葉地区青年キャンプ アンケート
		</h1>
		<p slot="description" class="description">
			2025年9月14日〜15日
		</p>
	</Header>

	<Main>
		<!-- <SurveyForm client:only /> -->
		<ExpiredMessage>
			<p class="notice">このアンケートは終了しています。</p>
		</ExpiredMessage>
	</Main>

	<Footer>
		<p class="footer-note">
			<small>© 2025 Keiyo Area United Youth Association.</small>
		</p>
	</Footer>
</FormLayout>

<style>
	.title {
		font-size: var(--text-xl);
		font-weight: bold;
		letter-spacing: -0.025em;

		@media (min-width: 768px) {
			font-size: var(--text-3xl);
		}
	}

	.description {
		font-size: var(--text-sm);
		color: var(--color-blue-100);

		@media (min-width: 768px) {
			font-size: var(--text-base);
		}
	}

	.notice {
		margin-block: var(--space-4);
	}

	.footer-note {
		padding-top: var(--space-12);
	}
</style>
