---
import "@/styles/themes/indigo.css";
import ExpiredMessage from "@/components/forms/ExpiredMessage.tsx";
import FormLayout from "@/layouts/FormLayout.astro";
---

<FormLayout title="京葉地区合同青年会 参加申し込み">
	<div class="page">
		<header class="page-header">
			<div class="page-header-inner">
				<h1 class="title">
					京葉地区合同青年会 参加申し込み
				</h1>
				<p class="description">
					2026年2月22日
				</p>
			</div>
			<div class="wave">
				<svg viewBox="0 0 1200 120" preserveAspectRatio="none">
					<path d="M0,60 C300,30 900,90 1200,60 L1200,120 L0,120 Z"></path>
				</svg>
			</div>
		</header>

		<main class="page-main">
			<div class="page-main-inner">
				<ExpiredMessage>
					<p class="notice">この申し込みは終了しています。</p>
				</ExpiredMessage>
			</div>
		</main>

		<footer class="page-footer">
			<div class="page-footer-inner">
				<p class="footer-note">
					<small>© 2026 Keiyo Area United Youth Association.</small>
				</p>
			</div>
		</footer>
	</div>
</FormLayout>

<style>
	:global(body) {
		background-color: var(--color-indigo-600);
	}

	.page {
		background-color: var(--color-slate-100);
		background-image: url("/bg-pattern-1.svg"), url("/bg-pattern-2.svg");
		background-size: 800px 800px, 1200px 1200px;
		background-position: 0 0, 180px 250px;
		min-height: 100dvh;
		color: var(--color-gray-700);
	}

	.page-header {
		position: relative;
		background: linear-gradient(
			to bottom right,
			var(--color-indigo-600),
			var(--color-blue-600),
			var(--color-purple-700)
		);
		color: white;
	}

	.page-header-inner {
		max-width: 48rem;
		margin-inline: auto;
		padding: var(--space-4);
		min-height: 35vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.wave {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
	}

	.wave path {
		fill: var(--color-slate-100);
	}

	.wave svg {
		width: 100%;
		height: 2rem;

		@media (min-width: 768px) {
			height: 3rem;
		}
	}

	.page-main {
		min-height: 45vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.page-main-inner {
		width: 32rem;
		max-width: 100%;
		margin-inline: auto;
		padding-top: var(--space-10);
		padding-bottom: var(--space-20);
		padding-inline: var(--space-4);
	}

	.page-footer {
		background: linear-gradient(
			to right,
			var(--color-indigo-700),
			var(--color-purple-800)
		);
		color: var(--color-blue-100);
	}

	.page-footer-inner {
		max-width: 48rem;
		margin-inline: auto;
		padding: var(--space-4);
		min-height: 20vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.title {
		font-size: var(--text-xl);
		font-weight: bold;

		@media (min-width: 768px) {
			font-size: var(--text-3xl);
		}
	}

	.description {
		margin-top: var(--space-8);
		font-size: var(--text-lg);
		color: var(--color-blue-100);
	}

	.notice {
		margin-block: var(--space-4);
	}

	.footer-note {
		padding-top: var(--space-12);
	}
</style>
