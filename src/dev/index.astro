---
import { readdirSync } from "node:fs";
import { fileURLToPath } from "node:url";

const pages = readdirSync(fileURLToPath(new URL("../pages", import.meta.url)), {
	recursive: true,
	encoding: "utf8",
})
	.filter((f) => f.endsWith(".astro"))
	.map((f) => `/${f.replace(/\\/g, "/").replace(/\.astro$/, "")}`)
	.filter((p) => p !== "/404")
	.sort();
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Dev: Pages Index</title>
	</head>
	<body>
		<ul>
			{pages.map((url) => (
				<li><a href={url}>{url}</a></li>
			))}
		</ul>
		<style>
			body {
				margin: 0;
				font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
				background: #0f172a;
				color: #e2e8f0;
				min-height: 100dvh;
				display: grid;
				place-items: center;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.125rem;
			}
			li a {
				display: block;
				padding: 0.375rem 0.625rem;
				color: #93c5fd;
				text-decoration: none;
				border-radius: 4px;
				font-size: 0.875rem;
			}
			li a:hover {
				background: #1e293b;
				color: #bfdbfe;
			}
		</style>
	</body>
</html>
