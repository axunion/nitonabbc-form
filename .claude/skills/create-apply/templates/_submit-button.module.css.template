.button {
	width: 100%;
	padding: var(--space-3) var(--space-4);
	background: linear-gradient(
		to right,
		var(--color-indigo-600),
		var(--color-blue-600)
	);
	color: white;
	font-size: var(--text-base);
	font-weight: bold;
	border: none;
	border-radius: 0.5rem;
	cursor: pointer;
	transition: opacity 0.15s ease;

	&:hover:not(:disabled) {
		opacity: 0.9;
	}

	&:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}
}
