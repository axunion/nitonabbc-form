/* Duplicated from global.css: CSS Modules scope animation idents locally,
   so referencing global.css's @keyframes by name here wouldn't resolve. */
@keyframes fadeIn {
	from {
		opacity: 0;
	}
	to {
		opacity: 1;
	}
}

.form {
	display: flex;
	flex-direction: column;
	gap: var(--space-2);
	animation: fadeIn 0.3s ease-out;
}
