.vertical {
	display: flex;
	flex-direction: column;
	gap: var(--space-2);
}

.horizontal {
	display: flex;
	flex-wrap: wrap;
	gap: var(--space-2) var(--space-4);
}

.label {
	display: flex;
	align-items: center;
	gap: var(--space-2);
	cursor: pointer;
	font-size: var(--text-base);
	color: var(--color-gray-700);

	&:has(:disabled) {
		opacity: 0.6;
		cursor: not-allowed;
	}
}

.radio {
	accent-color: var(--color-indigo-600);
	width: 1rem;
	height: 1rem;
	flex-shrink: 0;
}
