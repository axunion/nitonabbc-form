      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.gnupg/*)",
      "Bash(head ~/.ssh/*)",
      "Bash(head ~/.aws/*)",
      "Bash(head ~/.gnupg/*)",
      "Bash(tail ~/.ssh/*)",
      "Bash(tail ~/.aws/*)",
      "Bash(tail ~/.gnupg/*)",
      "Bash(less ~/.ssh/*)",
      "Bash(less ~/.aws/*)",
      "Bash(less ~/.gnupg/*)",
      "Bash(more ~/.ssh/*)",
