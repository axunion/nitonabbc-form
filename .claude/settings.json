      "Bash(git push --delete *)",
      "Bash(git push --mirror *)",
      "Bash(git tag -d *)",
      "Bash(git tag --delete *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(git worktree remove *)",
      "Bash(git submodule deinit *)",
      "Bash(gh repo delete *)",
      "Bash(gh ssh-key add *)",
      "Bash(gh auth logout *)",
      "Bash(gh secret *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -R *)",
      "Bash(rm -Rf *)",
      "Bash(rm -fR *)",
      "Bash(rm --recursive *)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(xargs rm *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(git config *)",
