{
  "enabledMcpjsonServers": ["context7"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(src/pages/*/*/**)",
            "command": "sh .claude/hooks/guard-past-page.sh"
          },
          {
            "type": "command",
            "if": "Edit(src/pages/*/*/**)",
            "command": "sh .claude/hooks/guard-past-page.sh"
          }
        ]
      }
    ]
  }
}
