      "Bash(head ~/.npmrc)",
      "Bash(head ~/.pypirc)",
      "Bash(head ~/.kube/*)",
      "Bash(head ~/.docker/*)",
      "Bash(head ~/.config/gcloud/*)",
      "Bash(tail ~/.netrc)",
      "Bash(tail ~/.npmrc)",
      "Bash(tail ~/.pypirc)",
      "Bash(tail ~/.kube/*)",
      "Bash(tail ~/.docker/*)",
      "Bash(tail ~/.config/gcloud/*)",
      "Bash(less ~/.netrc)",
      "Bash(less ~/.npmrc)",
      "Bash(less ~/.pypirc)",
      "Bash(less ~/.kube/*)",
      "Bash(less ~/.docker/*)",
      "Bash(less ~/.config/gcloud/*)",
      "Bash(more ~/.netrc)",
      "Bash(more ~/.npmrc)",
      "Bash(more ~/.pypirc)",
      "Bash(more ~/.kube/*)",
      "Bash(more ~/.docker/*)",
      "Bash(more ~/.config/gcloud/*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gcloud/**)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Edit(~/.zshenv)",
