    "@biomejs/biome": "2.4.15",
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "lefthook": "^2.1.8",
    "typescript": "~5.8.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  }
