{
  "name": "nitonabbc-form",
  "type": "module",
  "version": "0.0.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
