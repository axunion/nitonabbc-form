# reCAPTCHA v3 site key (obtain from Google reCAPTCHA Admin Console)
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# Google Apps Script endpoints (URLs issued after GAS deployment)
# Form submission (apply / survey)
PUBLIC_POST_TO_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Fetch data from spreadsheet (used by apply-confirm page)
PUBLIC_FETCH_FROM_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Initialize spreadsheet (used when registering a new event)
PUBLIC_CREATE_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
